{
  "name": "magiloom-server",
  "version": "0.0.0",
  "description": "Headless Magiloom backend — hosts the DragonRealms game connection, Lich, and script engine over WebSocket for the PWA / remote clients.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "vapid": "web-push generate-vapid-keys"
  },
  "dependencies": {
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
